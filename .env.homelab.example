# Homelab (px1 / VM 107) env — template. Copy to `.env.homelab` (gitignored) on
# the VM and fill from 1Password (vault `AC-DevOps`). NEVER commit real secrets.
#
# Used with:  docker compose -f docker-compose.yml -f docker-compose.homelab.yml --env-file .env.homelab up -d
#
# Substrate handles are pinned by the infra contract:
#   home-network/docs/2026-05-27-siai-deployment-handoff.md

# --- Registry --------------------------------------------------------------
REGISTRY_BACKEND=harbor

# --- pg1 (LAN-direct 192.168.4.50 — no tailnet ACL, no MagicDNS) -----------
# ⚠ The 1P item titles contain "@", which breaks `op read`. Use `op item get`:
#   GITEA_DB_PASSWORD=$(op item get "gitea - app role @ pg1"     --vault AC-DevOps --fields password --reveal)
#   WOODPECKER_DB_PASSWORD=$(op item get "woodpecker - app role @ pg1" --vault AC-DevOps --fields password --reveal)
GITEA_DB_PASSWORD=
WOODPECKER_DB_PASSWORD=

# --- Woodpecker ↔ Gitea OAuth (internal CI auth) ---------------------------
# Created in Gitea after first boot (Woodpecker OAuth app); see task 4.3.
WOODPECKER_GITEA_CLIENT=
WOODPECKER_GITEA_SECRET=
# openssl rand -hex 32  (must match agent + server)
WOODPECKER_AGENT_SECRET=
# Woodpecker admin — must match the Gitea admin username for OAuth login.
WOODPECKER_ADMIN=admin

# --- Tailscale ingress sidecars (gitea. + ci.) ------------------------------
# One-shot, tag:host auth-keys. The VM's own join consumed
# `siai - tailnet auth-key - cat-bluegill`; MINT A FRESH KEY PER SIDECAR
# (human step — ask the operator). Then:
#   TS_AUTHKEY_GITEA=$(op read "op://AC-DevOps/siai-gitea - tailnet auth-key - cat-bluegill/password")
#   TS_AUTHKEY_CI=$(op read    "op://AC-DevOps/siai-ci - tailnet auth-key - cat-bluegill/password")
TS_AUTHKEY_GITEA=
TS_AUTHKEY_CI=

# Sidecar tailnet IPs — fill AFTER the sidecars first join (task 4.2), then
# recreate gitea + wpk-server so their extra_hosts pins take effect:
#   GITEA_TS_IP=$(docker exec siai-gitea-ts tailscale ip -4)
#   CI_TS_IP=$(docker exec siai-ci-ts tailscale ip -4)
GITEA_TS_IP=
CI_TS_IP=

# --- Harbor push (Woodpecker secret, NOT compose env) -----------------------
# Add as a Woodpecker org/repo secret at deploy — robot$siai-ci, scoped to
# `direction`. ⚠ The token is in the `credential` field (not `password`):
#   registry_url      = harbor.cat-bluegill.ts.net
#   registry_username = robot$siai-ci
#   registry_password = $(op read "op://AC-DevOps/harbor - siai-ci robot/credential")
