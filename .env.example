WOODPECKER_HOST=http://ci.localhost
GITEA_EXTERNAL_URL=http://gitea.localhost

# PostgreSQL (shared by Gitea and Woodpecker)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Gitea admin (used by 'just gitea-init')
GITEA_ADMIN=admin
GITEA_ADMIN_EMAIL=admin@localhost
GITEA_ADMIN_PASSWORD=admin123

# Generate with: openssl rand -hex 32
WOODPECKER_AGENT_SECRET=change-me-openssl-rand

# From Gitea OAuth app (Redirect URI: http://ci.localhost/authorize)
WOODPECKER_GITEA_CLIENT=your-oauth-client-id
WOODPECKER_GITEA_SECRET=your-oauth-client-secret

# Woodpecker admin user (can set repos as trusted for Docker builds)
# Must match Gitea username for OAuth login
WOODPECKER_ADMIN=admin

# ══════════════════════════════════════════════════════════════════════════════
# CONTAINER REGISTRY (optional Harbor backend)
# ══════════════════════════════════════════════════════════════════════════════

# Registry backend: gitea (default) or harbor
# - gitea: Uses Gitea's built-in registry at 127.0.0.1/v2/*
# - harbor: Deploys Harbor at registry.localhost with enterprise features
REGISTRY_BACKEND=gitea

# Harbor configuration (only used when REGISTRY_BACKEND=harbor)
HARBOR_ADMIN_PASSWORD=Harbor12345
HARBOR_DB_PASSWORD=postgres

# Harbor internal secrets (generate with: openssl rand -hex 16)
HARBOR_CORE_SECRET=harbor-core-secret-key-change-me
HARBOR_JOBSERVICE_SECRET=harbor-jobservice-secret
HARBOR_REGISTRY_SECRET=harbor-registry-secret

# Enable Trivy vulnerability scanner (requires more resources)
HARBOR_TRIVY_ENABLED=false

# Optional: GitHub token for Trivy to avoid rate limits on vulnerability DB
# TRIVY_GITHUB_TOKEN=ghp_xxxxxxxxxxxx
